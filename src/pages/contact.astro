---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact | Tied With Kara">
	<main class="pt-48 pb-32 min-h-screen bg-linen">
		
		<!-- Header -->
		<div class="max-w-7xl mx-auto px-6 mb-20 text-center">
			<h1 class="text-4xl md:text-6xl font-serif text-sage mb-6 leading-normal">Let's Connect</h1>
			<p class="text-lg text-sage-light tracking-widest uppercase border-b border-bronze pb-4 inline-block">
				Begin your journey here
			</p>
		</div>

		<!-- Contact Section -->
		<div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-16 lg:gap-24">
			
			<!-- Left Side: Information -->
			<div class="flex flex-col justify-center">
				<h2 class="text-3xl font-serif text-sage mb-6">We'd love to hear your story.</h2>
				<p class="text-sage/80 mb-12 font-light leading-relaxed">
					Whether you have a clear vision or are just beginning to dream, we are here to bring your perfect day to life. Fill out the inquiry form, and Kara will be in touch within 48 hours to schedule a complimentary consultation.
				</p>
				
				<div class="space-y-6 text-sage/90 font-light">
					<div>
						<p class="text-xs tracking-widest uppercase text-bronze mb-1">Email</p>
						<a href="mailto:kara@tiedwithkara.com" class="hover:text-bronze transition-colors">kara@tiedwithkara.com</a>
					</div>
					<div>
						<p class="text-xs tracking-widest uppercase text-bronze mb-1">Office Hours</p>
						<p>Tuesday - Saturday | 10am - 5pm</p>
					</div>
					<div>
						<p class="text-xs tracking-widest uppercase text-bronze mb-1">Location</p>
						<p>Serving Virginia & Beyond</p>
					</div>
				</div>
			</div>

			<!-- Right Side: The Form -->
			<div class="bg-linen p-8 md:p-12 shadow-2xl border border-sage/10 relative">
				<!-- Decorative corner accent -->
				<div class="absolute top-0 left-0 w-8 h-8 border-t border-l border-sage/40 -translate-x-4 -translate-y-4"></div>
				<div class="absolute bottom-0 right-0 w-8 h-8 border-b border-r border-sage/40 translate-x-4 translate-y-4"></div>

				<form class="space-y-8" onsubmit="event.preventDefault(); alert('Form submission ready to be connected!');">
					
					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						<!-- Name -->
						<div class="relative group">
							<input type="text" id="name" required class="w-full bg-transparent border-b border-sage/30 py-2 text-sage focus:outline-none focus:border-sage transition-colors placeholder-transparent peer" placeholder="Your Name" />
							<label for="name" class="absolute left-0 -top-4 text-xs tracking-widest uppercase text-sage/60 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-sage/40 peer-placeholder-shown:top-2 peer-focus:-top-4 peer-focus:text-xs peer-focus:text-bronze">Your Name</label>
						</div>
						
						<!-- Partner's Name -->
						<div class="relative group">
							<input type="text" id="partner" class="w-full bg-transparent border-b border-sage/30 py-2 text-sage focus:outline-none focus:border-sage transition-colors placeholder-transparent peer" placeholder="Partner's Name" />
							<label for="partner" class="absolute left-0 -top-4 text-xs tracking-widest uppercase text-sage/60 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-sage/40 peer-placeholder-shown:top-2 peer-focus:-top-4 peer-focus:text-xs peer-focus:text-bronze">Partner's Name</label>
						</div>
					</div>

					<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
						<!-- Email -->
						<div class="relative group">
							<input type="email" id="email" required class="w-full bg-transparent border-b border-sage/30 py-2 text-sage focus:outline-none focus:border-sage transition-colors placeholder-transparent peer" placeholder="Email Address" />
							<label for="email" class="absolute left-0 -top-4 text-xs tracking-widest uppercase text-sage/60 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-sage/40 peer-placeholder-shown:top-2 peer-focus:-top-4 peer-focus:text-xs peer-focus:text-bronze">Email Address</label>
						</div>
						
						<!-- Wedding Date -->
						<div class="relative group">
							<input type="date" id="date" class="w-full bg-transparent border-b border-sage/30 py-2 text-sage focus:outline-none focus:border-sage transition-colors peer" />
							<label for="date" class="absolute left-0 -top-4 text-xs tracking-widest uppercase text-sage/60 text-bronze">Proposed Date</label>
						</div>
					</div>

					<!-- Service Interest -->
					<div class="relative group">
						<select id="service" class="w-full bg-transparent border-b border-sage/30 py-2 text-sage focus:outline-none focus:border-sage transition-colors appearance-none cursor-pointer">
							<option value="" disabled selected class="text-sage/40">Select a Service</option>
							<option value="day-of" class="bg-linen text-sage">Day of Coordination</option>
							<option value="full-planning" class="bg-linen text-sage">Full Planning & Coordination</option>
							<option value="custom" class="bg-linen text-sage">Custom / A La Carte</option>
						</select>
						<!-- Custom dropdown arrow -->
						<div class="absolute right-0 top-3 pointer-events-none text-sage/60">▼</div>
						<label for="service" class="absolute left-0 -top-4 text-xs tracking-widest uppercase text-sage/60 text-bronze">Interested In</label>
					</div>

					<!-- Message -->
					<div class="relative group">
						<textarea id="message" rows="4" required class="w-full bg-transparent border-b border-sage/30 py-2 text-sage focus:outline-none focus:border-sage transition-colors placeholder-transparent peer resize-none" placeholder="Tell us about your vision..."></textarea>
						<label for="message" class="absolute left-0 -top-4 text-xs tracking-widest uppercase text-sage/60 transition-all peer-placeholder-shown:text-base peer-placeholder-shown:text-sage/40 peer-placeholder-shown:top-2 peer-focus:-top-4 peer-focus:text-xs peer-focus:text-bronze">Tell us about your vision...</label>
					</div>

					<button type="submit" class="w-full py-4 bg-sage text-linen text-sm tracking-widest uppercase hover:bg-bronze transition-colors duration-300">
						Send Inquiry
					</button>

				</form>
			</div>

		</div>
	</main>
</Layout>