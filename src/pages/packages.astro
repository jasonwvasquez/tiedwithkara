---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Packages | Tied With Kara">
	<main class="pt-48 pb-32 min-h-screen bg-linen">
		
		<!-- Header -->
		<div class="max-w-7xl mx-auto px-6 mb-24 text-center">
			<h1 class="text-4xl md:text-6xl font-serif text-sage mb-6 leading-normal">Our Services</h1>
			<p class="text-lg text-sage-light tracking-widest uppercase border-b border-bronze pb-4 inline-block">
				Curated for your perfect day
			</p>
		</div>

		<!-- Packages Grid -->
		<div class="max-w-6xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 items-stretch">
			
			<!-- TIER 1: Day of Coordination (Light Theme) -->
			<div class="border border-sage/30 p-10 md:p-14 flex flex-col relative group hover:border-sage transition-colors duration-500">
				<h2 class="text-3xl font-serif text-sage mb-4">Day of Coordination</h2>
				<p class="text-sage/80 mb-10 font-light leading-relaxed h-20">
					For the couple who has planned their dream wedding but wants to hand over the reins so they can be fully present.
				</p>
				
				<div class="border-t border-sage/20 w-12 mb-10"></div>
				
				<ul class="space-y-5 mb-14 flex-grow font-light text-sage/90">
					<li class="flex items-start">
						<span class="text-bronze mr-4 mt-1 text-xs">✦</span>
						<span>Timeline creation and vendor management</span>
					</li>
					<li class="flex items-start">
						<span class="text-bronze mr-4 mt-1 text-xs">✦</span>
						<span>1-2 venue walkthroughs prior to the day</span>
					</li>
					<li class="flex items-start">
						<span class="text-bronze mr-4 mt-1 text-xs">✦</span>
						<span>Rehearsal coordination</span>
					</li>
					<li class="flex items-start">
						<span class="text-bronze mr-4 mt-1 text-xs">✦</span>
						<span>10 hours of on-site execution and styling</span>
					</li>
					<li class="flex items-start">
						<span class="text-bronze mr-4 mt-1 text-xs">✦</span>
						<span>Complete teardown and gift management</span>
					</li>
				</ul>
				
				<a href="/contact" class="mt-auto block text-center px-8 py-4 border border-sage text-sage text-sm tracking-widest uppercase hover:bg-sage hover:text-linen transition-colors duration-300">
					Inquire
				</a>
			</div>

			<!-- TIER 2: Full Planning (Dark/Premium Theme) -->
			<div class="bg-sage p-10 md:p-14 flex flex-col relative shadow-2xl transform md:-translate-y-4">
				<!-- Subtle "Premium" tag -->
				<div class="absolute top-0 right-10 -translate-y-1/2 bg-bronze text-linen text-xs tracking-widest uppercase px-4 py-1">
					The Signature
				</div>

				<h2 class="text-3xl font-serif text-linen mb-4">Full Planning & Coordination</h2>
				<p class="text-linen/80 mb-10 font-light leading-relaxed h-20">
					A comprehensive, white-glove experience from the moment you get engaged to your final grand exit.
				</p>
				
				<div class="border-t border-linen/20 w-12 mb-10"></div>
				
				<ul class="space-y-5 mb-14 flex-grow font-light text-linen/90">
					<li class="flex items-start">
						<span class="text-gold mr-4 mt-1 text-xs">✦</span>
						<span>Everything in Day of Coordination</span>
					</li>
					<li class="flex items-start">
						<span class="text-gold mr-4 mt-1 text-xs">✦</span>
						<span>Budget curation and management</span>
					</li>
					<li class="flex items-start">
						<span class="text-gold mr-4 mt-1 text-xs">✦</span>
						<span>Venue scouting and contract negotiation</span>
					</li>
					<li class="flex items-start">
						<span class="text-gold mr-4 mt-1 text-xs">✦</span>
						<span>Custom mood boards and full aesthetic design</span>
					</li>
					<li class="flex items-start">
						<span class="text-gold mr-4 mt-1 text-xs">✦</span>
						<span>Unlimited communication and meetings</span>
					</li>
				</ul>
				
				<a href="/contact" class="mt-auto block text-center px-8 py-4 bg-linen text-sage text-sm tracking-widest uppercase hover:bg-bronze hover:text-linen transition-colors duration-300">
					Inquire
				</a>
			</div>

		</div>
		
		<!-- Optional Custom/A La Carte Note -->
		<div class="max-w-3xl mx-auto px-6 mt-24 text-center">
			<p class="text-sage/70 font-light italic">
				Looking for something unique? We also offer custom micro-wedding packages and à la carte styling services. 
				<a href="/contact" class="text-bronze underline hover:text-sage transition-colors">Let's chat.</a>
			</p>
		</div>

	</main>
</Layout>