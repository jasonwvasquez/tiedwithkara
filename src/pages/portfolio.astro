---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

// Eagerly load all images
const imageFiles = import.meta.glob<{ default: ImageMetadata }>('/src/assets/portfolio/*.{jpeg,jpg,JPEG,JPG,png,gif,webp}', { eager: true });
const images = Object.values(imageFiles).map(file => file.default);
---

<Layout title="Portfolio | Tied With Kara">
	<!-- FIX 1: Increased top padding (pt-48) so the header isn't cut off by the navbar -->
	<main class="pt-48 pb-24 min-h-screen bg-linen">
		
		<!-- Header -->
		<div class="max-w-7xl mx-auto px-6 mb-20 text-center">
			<h1 class="text-4xl md:text-6xl font-serif text-sage mb-6 leading-normal">Our Portfolio</h1>
			<p class="text-lg text-sage-light tracking-widest uppercase border-b border-bronze pb-4 inline-block">
				A Glimpse Into the Magic
			</p>
		</div>

		<!-- Masonry Gallery Grid -->
		<div class="max-w-7xl mx-auto px-6">
			<!-- FIX 2: Forced 2 columns on small screens, 3 on medium, 4 on large -->
			<div class="columns-2 md:columns-3 lg:columns-4 gap-4 md:gap-6">
				{images.map((img, index) => (
					<!-- FIX 3: Moved spacing to individual items (mb-4) to prevent column clipping -->
					<div class="mb-4 md:mb-6 break-inside-avoid overflow-hidden rounded-sm group cursor-pointer shadow-sm hover:shadow-xl transition-shadow duration-500">
						<Image 
							src={img} 
							alt="Tied With Kara Wedding Portfolio" 
							class="w-full h-auto object-cover transform transition-transform duration-700 group-hover:scale-105 gallery-image"
							quality="high"
							data-image-src={img.src} 
						/>
					</div>
				))}
			</div>
		</div>

		<!-- Lightbox Overlay (Hidden by default) -->
		<div id="lightbox" class="fixed inset-0 z-[100] bg-linen/95 backdrop-blur-md hidden flex-col items-center justify-center p-4 md:p-12 opacity-0 transition-opacity duration-300">
			<!-- Close Button -->
			<button id="close-lightbox" class="absolute top-6 right-6 md:top-10 md:right-10 text-sage hover:text-bronze transition-colors">
				<svg xmlns="http://www.w3.org/2000/svg" class="h-10 w-10" fill="none" viewBox="0 0 24 24" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />
				</svg>
			</button>
			
			<!-- Fullscreen Image -->
			<img id="lightbox-image" src="" alt="Enlarged wedding photo" class="max-w-full max-h-full object-contain shadow-2xl rounded-sm" />
		</div>
		
	</main>
</Layout>

<!-- Javascript to make the Lightbox work -->
<script>
	const images = document.querySelectorAll('.gallery-image');
	const lightbox = document.getElementById('lightbox');
	const lightboxImage = document.getElementById('lightbox-image') as HTMLImageElement;
	const closeBtn = document.getElementById('close-lightbox');

	// Open Lightbox
	images.forEach(img => {
		img.addEventListener('click', (e) => {
			const target = e.target as HTMLImageElement;
			if (lightbox && lightboxImage) {
				lightboxImage.src = target.getAttribute('data-image-src') || '';
				lightbox.classList.remove('hidden');
				lightbox.classList.add('flex');
				// Tiny delay to allow display:flex to apply before fading in
				setTimeout(() => lightbox.classList.remove('opacity-0'), 10);
				document.body.style.overflow = 'hidden'; // Stop background scrolling
			}
		});
	});

	// Close Lightbox function
	const closeLightbox = () => {
		if (lightbox) {
			lightbox.classList.add('opacity-0');
			setTimeout(() => {
				lightbox.classList.add('hidden');
				lightbox.classList.remove('flex');
				document.body.style.overflow = 'auto'; // Restore scrolling
			}, 300); // Matches the duration-300 transition
		}
	};

	// Close on click or Escape key
	closeBtn?.addEventListener('click', closeLightbox);
	lightbox?.addEventListener('click', (e) => {
		if (e.target === lightbox) closeLightbox(); // Close if clicking the background
	});
	document.addEventListener('keydown', (e) => {
		if (e.key === 'Escape') closeLightbox();
	});
</script>