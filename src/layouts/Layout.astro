---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Tied With Kara - Bespoke Wedding Planning" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0" />
		<!-- Fixed Favicon Path -->
		<link rel="icon" type="image/svg+xml" href="/tiedwithkara/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-linen text-sage antialiased flex flex-col min-h-screen">
		
		<!-- Navigation Bar -->
		<nav class="fixed w-full top-0 z-[100] bg-linen/90 backdrop-blur-sm border-b border-sage-light/30">
			<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
				<a href="/tiedwithkara/" class="text-2xl font-serif text-sage tracking-wide hover:text-bronze transition-colors z-[110]">TWK.</a>
				
				<!-- Desktop Menu -->
				<ul class="hidden md:flex space-x-8 text-sm tracking-widest uppercase text-sage">
					<li><a href="/tiedwithkara/" class="hover:text-bronze transition-colors">Home</a></li>
					<li><a href="/tiedwithkara/portfolio" class="hover:text-bronze transition-colors">Portfolio</a></li>
					<li><a href="/tiedwithkara/packages" class="hover:text-bronze transition-colors">Packages</a></li>
					<li><a href="/tiedwithkara/about" class="hover:text-bronze transition-colors">About</a></li>
					<li><a href="/tiedwithkara/contact" class="hover:text-bronze transition-colors">Contact</a></li>
				</ul>

				<!-- Hamburger Button -->
				<button id="menu-button" class="md:hidden text-sage focus:outline-none p-2 z-[110]" aria-label="Toggle Menu">
					<svg id="menu-icon" xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7" />
					</svg>
				</button>
			</div>

			<!-- Mobile Menu Overlay (Redesigned for Safari) -->
			<div id="mobile-menu" class="fixed top-0 left-0 w-full h-[100dvh] bg-linen z-[105] flex flex-col items-center justify-center transition-all duration-300 opacity-0 pointer-events-none invisible">
				<div class="flex flex-col items-center space-y-8 text-3xl font-serif text-sage">
					<a href="/tiedwithkara/" class="mobile-link hover:text-bronze transition-colors">Home</a>
					<a href="/tiedwithkara/portfolio" class="mobile-link hover:text-bronze transition-colors">Portfolio</a>
					<a href="/tiedwithkara/packages" class="mobile-link hover:text-bronze transition-colors">Packages</a>
					<a href="/tiedwithkara/about" class="mobile-link hover:text-bronze transition-colors">About</a>
					<a href="/tiedwithkara/contact" class="mobile-link hover:text-bronze transition-colors">Contact</a>
				</div>
				<div class="absolute bottom-12 text-center">
					<span class="text-bronze text-xs tracking-[0.3em] uppercase">Tied With Kara</span>
				</div>
			</div>
		</nav>

		<!-- Page Content -->
		<div class="flex-grow">
			<slot />
		</div>
		
		<!-- Global Footer -->
		<footer class="bg-sage text-linen pt-20 pb-10 mt-auto">
			<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 mb-16">
				
				<div class="md:col-span-1">
					<a href="/tiedwithkara/" class="text-3xl font-serif tracking-wide block mb-6 text-linen hover:text-bronze transition-colors">TWK.</a>
					<p class="text-linen/70 font-light text-sm leading-relaxed pr-4">
						Bespoke wedding planning and design, curating unforgettable moments with minimalist elegance.
					</p>
				</div>

				<div>
					<h3 class="text-bronze text-xs tracking-widest uppercase mb-6">Explore</h3>
					<ul class="space-y-4 font-light text-sm text-linen/80">
						<li><a href="/tiedwithkara/" class="hover:text-bronze transition-colors">Home</a></li>
						<li><a href="/tiedwithkara/portfolio" class="hover:text-bronze transition-colors">Portfolio</a></li>
						<li><a href="/tiedwithkara/packages" class="hover:text-bronze transition-colors">Packages</a></li>
						<li><a href="/tiedwithkara/about" class="hover:text-bronze transition-colors">About</a></li>
					</ul>
				</div>

				<div>
					<h3 class="text-bronze text-xs tracking-widest uppercase mb-6">Connect</h3>
					<ul class="space-y-4 font-light text-sm text-linen/80">
						<li><a href="/tiedwithkara/contact" class="hover:text-bronze transition-colors">Inquire Now</a></li>
						<li><a href="mailto:kara@tiedwithkara.com" class="hover:text-bronze transition-colors">kara@tiedwithkara.com</a></li>
						<li>Serving Virginia & Beyond</li>
					</ul>
				</div>

				<div>
					<h3 class="text-bronze text-xs tracking-widest uppercase mb-6">Follow</h3>
					<ul class="space-y-4 font-light text-sm text-linen/80">
						<li><a href="#" class="hover:text-bronze transition-colors">Instagram</a></li>
						<li><a href="#" class="hover:text-bronze transition-colors">Pinterest</a></li>
					</ul>
				</div>

			</div>

			<div class="max-w-7xl mx-auto px-6 pt-8 border-t border-linen/20 flex flex-col md:flex-row justify-between items-center text-xs font-light text-linen/50">
				<p>&copy; {new Date().getFullYear()} Tied With Kara. All rights reserved.</p>
				<p class="mt-4 md:mt-0">Designed with intent.</p>
			</div>
		</footer>

		<script is:inline>
			// Using a self-executing function to avoid global variable conflicts
			(function() {
				const setup = () => {
					const btn = document.getElementById('menu-button');
					const menu = document.getElementById('mobile-menu');
					const icon = document.getElementById('menu-icon');
					const links = document.querySelectorAll('.mobile-link');
					let isOpen = false;

					if (!btn || !menu) return;

					const toggle = () => {
						isOpen = !isOpen;
						if (isOpen) {
							menu.classList.remove('opacity-0', 'pointer-events-none', 'invisible');
							menu.classList.add('opacity-100', 'pointer-events-auto', 'visible');
							if (icon) icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M6 18L18 6M6 6l12 12" />';
							document.body.style.overflow = 'hidden';
						} else {
							menu.classList.add('opacity-0', 'pointer-events-none', 'invisible');
							menu.classList.remove('opacity-100', 'pointer-events-auto', 'visible');
							if (icon) icon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16m-7 6h7" />';
							document.body.style.overflow = '';
						}
					};

					btn.addEventListener('click', toggle);
					links.forEach(l => l.addEventListener('click', () => isOpen && toggle()));
				};

				// Initialize on load
				setup();
				// Re-initialize if the content changes (good for Astro transitions)
				document.addEventListener('astro:after-swap', setup);
			})();
		</script>
	</body>
</html>