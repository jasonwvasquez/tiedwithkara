---
import '../styles/global.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="scroll-smooth">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Tied With Kara - Bespoke Wedding Planning" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>
	</head>
	<body class="bg-linen text-sage antialiased flex flex-col min-h-screen">
		
		<!-- Navigation Bar -->
		<nav class="fixed w-full top-0 z-50 bg-linen/90 backdrop-blur-sm border-b border-sage-light/30">
			<div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
				<!-- Add /tiedwithkara/ to the home link -->
				<a href="/tiedwithkara/" class="text-2xl font-serif text-sage tracking-wide hover:text-bronze transition-colors">TWK.</a>
				
				<ul class="hidden md:flex space-x-8 text-sm tracking-widest uppercase text-sage">
					<li><a href="/tiedwithkara/" class="hover:text-bronze transition-colors">Home</a></li>
					<li><a href="/tiedwithkara/portfolio" class="hover:text-bronze transition-colors">Portfolio</a></li>
					<li><a href="/tiedwithkara/packages" class="hover:text-bronze transition-colors">Packages</a></li>
					<li><a href="/tiedwithkara/about" class="hover:text-bronze transition-colors">About</a></li>
					<li><a href="/tiedwithkara/contact" class="hover:text-bronze transition-colors">Contact</a></li>
				</ul>
			</div>
		</nav>

		<!-- Page Content Injected Here -->
		<div class="flex-grow">
			<slot />
		</div>
		
		<!-- Global Footer -->
		<footer class="bg-sage text-linen pt-20 pb-10 mt-auto">
			<div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 md:gap-8 mb-16">
				
				<!-- Brand Column -->
				<div class="md:col-span-1">
					<a href="/tiedwithkara/" class="text-3xl font-serif tracking-wide block mb-6 text-linen hover:text-bronze transition-colors">TWK.</a>
					<p class="text-linen/70 font-light text-sm leading-relaxed pr-4">
						Bespoke wedding planning and design, curating unforgettable moments with minimalist elegance.
					</p>
				</div>

				<!-- Explore Links -->
				<div>
					<h3 class="text-bronze text-xs tracking-widest uppercase mb-6">Explore</h3>
					<ul class="space-y-4 font-light text-sm text-linen/80">
						<li><a href="/tiedwithkara/" class="hover:text-bronze transition-colors">Home</a></li>
						<li><a href="/tiedwithkara/portfolio" class="hover:text-bronze transition-colors">Portfolio</a></li>
						<li><a href="/tiedwithkara/packages" class="hover:text-bronze transition-colors">Packages</a></li>
						<li><a href="/tiedwithkara/about" class="hover:text-bronze transition-colors">About</a></li>
					</ul>
				</div>

				<!-- Contact Info -->
				<div>
					<h3 class="text-bronze text-xs tracking-widest uppercase mb-6">Connect</h3>
					<ul class="space-y-4 font-light text-sm text-linen/80">
						<li><a href="/tiedwithkara/contact" class="hover:text-bronze transition-colors">Inquire Now</a></li>
						<li><a href="mailto:kara@tiedwithkara.com" class="hover:text-bronze transition-colors">kara@tiedwithkara.com</a></li>
						<li>Serving Virginia & Beyond</li>
					</ul>
				</div>

				<!-- Socials -->
				<div>
					<h3 class="text-bronze text-xs tracking-widest uppercase mb-6">Follow</h3>
					<ul class="space-y-4 font-light text-sm text-linen/80">
						<li><a href="#" class="hover:text-bronze transition-colors">Instagram</a></li>
						<li><a href="#" class="hover:text-bronze transition-colors">Pinterest</a></li>
					</ul>
				</div>

			</div>

			<!-- Copyright Bar -->
			<div class="max-w-7xl mx-auto px-6 pt-8 border-t border-linen/20 flex flex-col md:flex-row justify-between items-center text-xs font-light text-linen/50">
				<!-- The {new Date().getFullYear()} ensures the year automatically updates every Jan 1st! -->
				<p>&copy; {new Date().getFullYear()} Tied With Kara. All rights reserved.</p>
				<p class="mt-4 md:mt-0">Designed with intent.</p>
			</div>
		</footer>
		
	</body>
</html>